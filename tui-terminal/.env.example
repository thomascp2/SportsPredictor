# ── tui-terminal/.env.example ────────────────────────────────────────────────
# Copy to .env and fill in your keys.
# The TUI loads this at startup via python-dotenv (pip install python-dotenv).
# DO NOT commit .env to git.

# ── Phase 3: Gemini Intelligence Layer (REQUIRED for Phase 3) ─────────────
# Get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Kalshi (REQUIRED for Rust ingester live Kalshi prices) ────────────────
# REST + WebSocket auth — create at https://kalshi.com/account/api
# The ingester uses these for /trade-api/v2/markets/orderbooks WebSocket
KALSHI_API_KEY=your_kalshi_api_key_here
KALSHI_API_SECRET=your_kalshi_api_secret_here

# ── Already in your main SportsPredictor env (no action needed) ───────────
# ANTHROPIC_API_KEY  — used by the orchestrator/pregame intel, not the TUI
# DISCORD_WEBHOOK_URL — orchestrator only
