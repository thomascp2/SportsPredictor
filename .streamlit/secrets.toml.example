# FreePicks Dashboard — Streamlit Cloud secrets template
# Copy to .streamlit/secrets.toml and fill in real values (never commit that file).
# When deploying to share.streamlit.io, add these as Streamlit Cloud secrets in the UI.

# ── Turso (cloud SQLite) ─────────────────────────────────────────────────────
TURSO_NHL_URL   = "libsql://your-nhl-db.turso.io"
TURSO_NHL_TOKEN = "eyJ..."

TURSO_NBA_URL   = "libsql://your-nba-db.turso.io"
TURSO_NBA_TOKEN = "eyJ..."

TURSO_MLB_URL   = "libsql://your-mlb-db.turso.io"
TURSO_MLB_TOKEN = "eyJ..."

TURSO_GOLF_URL   = "libsql://your-golf-db.turso.io"
TURSO_GOLF_TOKEN = "eyJ..."

# ── StatBot (xAI Grok natural language DB query) ─────────────────────────────
XAI_API_KEY = "xai-..."
