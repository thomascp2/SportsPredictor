# SportsPredictor + PEGASUS — Environment Variables Template
# Copy this to /opt/SportsPredictor/.env on the VPS
# Fill in ALL values from start_orchestrator.bat on your local machine
# After creating: chmod 600 /opt/SportsPredictor/.env

# ── Anthropic (Claude API — self-healing + analysis) ─────────────────────────
ANTHROPIC_API_KEY=

# ── Discord Webhooks (notifications from orchestrator) ───────────────────────
DISCORD_WEBHOOK_URL=
NHL_DISCORD_WEBHOOK=
NBA_DISCORD_WEBHOOK=
MLB_DISCORD_WEBHOOK=
GOLF_DISCORD_WEBHOOK=

# ── Discord Bot Token (discord_bot.py) ───────────────────────────────────────
DISCORD_BOT_TOKEN=

# ── Turso (cloud SQLite — predictions sync) ──────────────────────────────────
TURSO_NHL_URL=
TURSO_NHL_TOKEN=
TURSO_NBA_URL=
TURSO_NBA_TOKEN=
TURSO_MLB_URL=
TURSO_MLB_TOKEN=

# ── Odds API (free tier active — game totals) ────────────────────────────────
ODDS_API_KEY=

# ── Supabase (legacy — orchestrator sync, NOT PEGASUS) ───────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ── Optional ─────────────────────────────────────────────────────────────────
# XAI_API_KEY=         # pregame intel (if used)
# ODDS_API_KEY=        # already above
